# ─────────────────────────────────────────────────────────────
# Up for Learning — Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` to version control.
# ─────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Used for SEO canonical URLs,
# Open Graph, sitemap and structured data.
# Production: https://www.upforlearning.ro
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── MongoDB Atlas ────────────────────────────────────────────
# Connection string from your MongoDB Atlas cluster.
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/upforlearning?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/upforlearning?retryWrites=true&w=majority

# ── Admin authentication ─────────────────────────────────────
# The admin email used to sign in to /admin.
ADMIN_EMAIL=admin@upforlearning.ro
# A bcrypt hash of the admin password.
# Generate one with:  npm run seed:admin -- "your-password"
ADMIN_PASSWORD_HASH=$2a$12$replace_this_with_a_real_bcrypt_hash_value_000000000
# A long, random secret used to sign the admin session JWT (min 32 chars).
# Generate one with:  openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# ── Email notifications (SMTP) ───────────────────────────────
# SMTP credentials for the @upforlearning.ro mailbox provided by your host.
# If these are left empty the app still works — submissions are stored in
# MongoDB and the email step is skipped (logged as a warning on the server).
SMTP_HOST=smtp.your-host.ro
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@upforlearning.ro
SMTP_PASSWORD=your-mailbox-password
# Where enrollment notifications are delivered.
MAIL_TO=contact@upforlearning.ro
# The "from" address shown on outgoing mail.
MAIL_FROM="Up for Learning <contact@upforlearning.ro>"

# ── Integrations (optional placeholders) ─────────────────────
# Google Maps embed URL (Share → Embed a map → copy the src). A sensible
# placeholder for the Bucharest area is used when left empty.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
# Google Business "Write a review" / reviews link.
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=
# Social profiles.
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/upforlearning
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/upforlearning
# Analytics (optional). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── SEO (optional) ───────────────────────────────────────────
# Google Search Console verification token (the content="..." value of the
# meta tag). Leave empty until the property is verified.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Exact map coordinates for the center — copy from Google Maps (right-click →
# the first line are the lat, lng). Both must be set to emit GeoCoordinates.
NEXT_PUBLIC_GEO_LATITUDE=
NEXT_PUBLIC_GEO_LONGITUDE=
